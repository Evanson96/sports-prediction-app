PORT=5000
NODE_ENV=development
CLIENT_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
JSON_BODY_LIMIT=80kb
TRUST_PROXY=false
THESPORTSDB_API_KEY=your_thesportsdb_key_here
THESPORTSDB_CACHE_MS=300000
APP_TIMEZONE=Africa/Nairobi
DATABASE_URL=sqlite:server/data/app.sqlite

# Primary football provider.
# API-Football can supply countries, leagues, teams, fixtures, standings, H2H,
# lineups, injuries, statistics, predictions, and odds where your plan supports them.
API_FOOTBALL_KEY=your_api_football_key_here
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
API_FOOTBALL_CACHE_MS=300000
API_FOOTBALL_SEASON=
API_FOOTBALL_LEAGUE_SCAN_LIMIT=5

# Backup odds provider.
# Get a key from https://the-odds-api.com/ and paste it here.
ODDS_API_KEY=your_odds_api_key_here

# Optional odds feed settings.
# Regions: uk, eu, us, us2, au. Kenya-specific bookmaker coverage depends on your provider/plan.
ODDS_API_REGIONS=uk,eu
ODDS_API_MARKETS=h2h,totals
ODDS_API_BOOKMAKERS=
ODDS_API_CACHE_MS=90000
ODDS_BOOKMAKER_VIEW=kenya
KENYA_ODDS_API_BOOKMAKERS=sportpesa,betika,odibets,mozzartbet,betpawa,betway,onexbet

# Backup odds provider.
ODDS_API_IO_KEY=your_odds_api_io_key_here
ODDS_API_IO_BASE_URL=https://api.odds-api.io/v3
ODDS_API_IO_BOOKMAKERS=
ODDS_API_IO_CACHE_MS=60000

# Optional Mozzart Bet testing adapter. Keep disabled unless you have a real key
# and tournament IDs. This is not a SportPesa/Betika/Odibets/BetPawa direct feed.
ODDSPAPI_ENABLED=false
ODDSPAPI_KEY=your_oddspapi_key_here
ODDSPAPI_BASE_URL=https://api.oddspapi.io/v4
ODDSPAPI_BOOKMAKER=mozzartbet
ODDSPAPI_TOURNAMENT_IDS=
ODDSPAPI_CACHE_MS=60000

# Kenyan bookmaker direct feeds.
# SportPesa, Betika, Odibets and BetPawa should stay "Direct feed required"
# until you connect a real provider or partner feed that returns their prices.

# Local product analytics for production testing. Replace with a managed analytics provider before a large launch.
ANALYTICS_ENABLED=true
ANALYTICS_SALT=replace_with_a_long_random_salt
ANALYTICS_ADMIN_TOKEN=replace_with_a_long_random_admin_token
RATE_LIMIT_MAX_BUCKETS=5000
